# Cloud-style credential values
(^|[[:space:]])AWS_ACCESS_KEY_ID[[:space:]]*=[[:space:]]*[A-Z0-9]{16,}
(^|[[:space:]])AWS_SECRET_ACCESS_KEY[[:space:]]*=[[:space:]]*[A-Za-z0-9/+=]{20,}
(^|[[:space:]])S3_ACCESS_KEY[[:space:]]*=[[:space:]]*[A-Z0-9]{16,}
(^|[[:space:]])S3_SECRET_KEY[[:space:]]*=[[:space:]]*[A-Za-z0-9/+=]{20,}

# Header-style bearer tokens
Authorization:[[:space:]]*Bearer[[:space:]]+[A-Za-z0-9._-]{16,}
