# Credential-shaped environment assignments
(^|[[:space:]])[A-Z0-9_]*(PASSWORD|PASS|SECRET|SECRET_KEY|ACCESS_KEY|API_KEY|TOKEN)([A-Z0-9_]*)[[:space:]]*=[[:space:]]*[^<"'[:space:]#][^[:space:]#]{7,}
(^|[[:space:]])[A-Z0-9_]*DATABASE_URL[[:space:]]*=[[:space:]]*[A-Za-z][A-Za-z0-9+.-]*://[^<:@[:space:]#]+:[^<@[:space:]#]+@[^[:space:]#]+
